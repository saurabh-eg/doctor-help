# Doctor Help API Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001

# MongoDB Connection
# Option 1: Local MongoDB
MONGO_URI=mongodb://localhost:27017/doctor-help

# Option 2: MongoDB Atlas
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/doctor-help?retryWrites=true&w=majority

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# User ID counter collection (managed in DB, not as env var)

# OTP Settings
OTP_DEV_MODE=true



# Fast2SMS Configuration
FAST2SMS_API_KEY=your_api_key_from_fast2sms
FAST2SMS_SENDER_ID=your_dlt_approved_sender_id
FAST2SMS_TEMPLATE_ID=your_dlt_template_id
FAST2SMS_USE_DLT=true
# Route mode: auto | dlt | quick
FAST2SMS_ROUTE_MODE=dlt
FAST2SMS_TEMPLATE_TEXT=Your OTP for DoctorHelp login is {#var#}. It is valid for 10 minutes.

# Payment settings
# Keep PAYMENT_MODE=demo until PhonePe production access is approved.
PAYMENT_MODE=demo

# PhonePe placeholders (fill when production access is approved)
PHONEPE_MERCHANT_ID=your_phonepe_merchant_id
PHONEPE_SALT_KEY=your_phonepe_salt_key
PHONEPE_SALT_INDEX=1
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_CALLBACK_URL=https://your-domain.com/api/payments/webhook/phonepe

# Webhook & hardening placeholders
PAYMENT_WEBHOOK_SECRET=replace_when_gateway_is_live
PAYMENT_IDEMPOTENCY_TTL_MINUTES=30
PAYMENT_RECON_CRON=0 */6 * * *
